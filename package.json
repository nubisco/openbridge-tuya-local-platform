{
  "name": "@nubisco/openbridge-tuya-local-platform",
  "version": "1.4.0",
  "description": "OpenBridge plugin to control Tuya devices locally over LAN — supports both native (plugins[]) and Openbridge-compat (platforms[]) loading modes",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nubisco/openbridge-tuya-local-platform.git"
  },
  "author": "José Silva <jose@nubisco.io>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "openbridge-plugin",
    "tuya",
    "tuya-lan",
    "local"
  ],
  "openbridge": {
    "platform": "TuyaLocalPlatform",
    "displayName": "Tuya Local Platform"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "config.schema.json",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/",
    "types:check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "quality:check": "npm test && npm run lint && npm run format:check && npm run types:check",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "[ -n \"$CI\" ] || simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged && npm run quality:check",
    "pre-push": "npm run quality:check"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "npm run lint:fix",
      "npm run format"
    ],
    "*.{json,md,mts,mjs}": "npm run format"
  },
  "dependencies": {
    "async": "^3.2.6",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "hap-nodejs": ">=0.12.0"
  },
  "peerDependenciesMeta": {
    "hap-nodejs": {
      "optional": true
    }
  },
  "release": {
    "branches": [
      "master"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@semantic-release/github",
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "CHANGELOG.md"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]"
        }
      ]
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/async": "^3.2.24",
    "@types/node": "^20.19.37",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.1"
  }
}
